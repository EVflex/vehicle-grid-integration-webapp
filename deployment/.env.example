# Copy to .env and fill in. Both values are required.

# Your bare domain, no scheme, no www (the site answers on DOMAIN and
# www.DOMAIN; the API on api.DOMAIN).
DOMAIN=example.com

# Email Let's Encrypt uses for certificate-expiry notices.
ACME_EMAIL=you@example.com

# Optional: concurrent simulations per API worker (x2 workers).
# 1 is right for a 4 GB server; 2 for 8 GB.
#VGI_MAX_PARALLEL_SIMULATIONS=1
